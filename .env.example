# LLM — Anthropic API (parsing + deneyim paketi üretimi)
# Boş bırakılırsa uygulama mock modda çalışır.
ANTHROPIC_API_KEY=

# Model seçimi (opsiyonel). Varsayılan: claude-opus-4-8 (en iyi kalite).
# Ekonomik alternatif: claude-haiku-4-5 (~10 kat ucuz, parsing için yeterli).
# LOKAL_LLM_MODEL=claude-haiku-4-5

# Google Places API — mekan katmanı
GOOGLE_PLACES_API_KEY=

# OpenWeatherMap — hava durumu filtresi
OPENWEATHER_API_KEY=

# Web search — biletli/ücretsiz etkinlik katmanları (Tavily tercih, yoksa Serper)
TAVILY_API_KEY=
SERPER_API_KEY=

# SQLite dosya yolu (opsiyonel, varsayılan: ./data/lokal.db)
# DATABASE_PATH=./data/lokal.db

# Better Auth — oturum imzalama anahtarı (üret: openssl rand -hex 32)
BETTER_AUTH_SECRET=

# Şifre sıfırlama e-postaları — Resend (resend.com, ücretsiz katman).
# Boşsa mailler konsola yazılır (geliştirme modu).
RESEND_API_KEY=
# EMAIL_FROM="Lokál <onboarding@resend.dev>"

# Haftalık cron ucu için gizli anahtar (üret: openssl rand -hex 24)
CRON_SECRET=

# Moderatör e-postaları (virgülle ayrılmış)
ADMIN_EMAILS=

# Web push (VAPID) — üret: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:seninmailin@ornek.com

# AssemblyAI — sesli arama (assemblyai.com/dashboard/api-keys)
ASSEMBLYAI_API_KEY=

# NVIDIA NIM — Anthropic yoksa LLM yedeği (build.nvidia.com)
NVIDIA_API_KEY=
# LOKAL_NVIDIA_MODEL=meta/llama-3.3-70b-instruct
